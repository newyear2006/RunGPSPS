  <trk>
    <name>Lichs Runde</name>
    <desc>Los gehts vom Feuerseeparkplatz hoch auf die Hochstr&#228;&#223; und dann am Heidenbuckel vorbei zur Lichs mit Blick &#252;ber Bargau und wieder zur&#252;ck zum Parkplatz. Befestigte Strasse mit meistens Schotter und etwas Asphaltanteil zu Beginn und am Schlu&#223;.</desc>
    <extensions>
        <sport>walking</sport>
        <type>C</type>
        <trackQuality>3</trackQuality>
        <isPublic>true</isPublic>
        <ascent>0.0</ascent>
        <descent>0.0</descent>
        <maxLat>-1000.0</maxLat>
        <minLat>1000.0</minLat>
        <maxLng>-1000.0</maxLng>
        <minLng>1000.0</minLng>
    </extensions>
